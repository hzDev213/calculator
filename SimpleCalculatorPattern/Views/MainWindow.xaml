<Window x:Class="Calculator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Calculator.ViewModels"
        Title="SimpleCalculator MVVM + Command"
        Width="340" Height="520"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.DataContext>
        <vm:CalculatorViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Стиль: кнопка-цифра -->
        <Style x:Key="DigitBtn" TargetType="Button">
            <Setter Property="Background"   Value="#313244"/>
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="FontSize"     Value="20"/>
            <Setter Property="Margin"       Value="4"/>
            <Setter Property="Height"       Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль: кнопка-оператор -->
        <Style x:Key="OpBtn" TargetType="Button" BasedOn="{StaticResource DigitBtn}">
            <Setter Property="Background" Value="#7F849C"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9399B2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль: кнопка-равно -->
        <Style x:Key="EqBtn" TargetType="Button" BasedOn="{StaticResource DigitBtn}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Стиль: функциональная кнопка (C, ±, ⌫) -->
        <Style x:Key="FnBtn" TargetType="Button" BasedOn="{StaticResource DigitBtn}">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="FontSize"   Value="16"/>
        </Style>

        <!-- Стиль: Undo / Redo -->
        <Style x:Key="UndoBtn" TargetType="Button" BasedOn="{StaticResource DigitBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Height"     Value="40"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- дисплей -->
            <RowDefinition Height="Auto"/>  <!-- undo/redo -->
            <RowDefinition Height="*"/>     <!-- кнопки -->
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Background="#181825" CornerRadius="10" Padding="12,8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="{Binding Expression}"
                           Foreground="#6C7086" FontSize="13"
                           HorizontalAlignment="Right" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DisplayValue}"
                           Foreground="#CDD6F4" FontSize="36" FontWeight="Light"
                           HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11" HorizontalAlignment="Left"
                           Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#6C7086"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="#F38BA8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Undo / Redo -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="↩ Undo" Style="{StaticResource UndoBtn}"
                    Command="{Binding UndoCommand}"
                    IsEnabled="{Binding CanUndo}"/>
            <Button Grid.Column="1" Content="↪ Redo" Style="{StaticResource UndoBtn}"
                    Command="{Binding RedoCommand}"
                    IsEnabled="{Binding CanRedo}"/>
        </Grid>

        <!-- Клавиши -->
        <UniformGrid Grid.Row="2" Rows="5" Columns="4">
            <!-- Row 1: C  ±  ⌫  ÷ -->
            <Button Content="C"  Style="{StaticResource FnBtn}"  Command="{Binding ClearCommand}"/>
            <Button Content="±"  Style="{StaticResource FnBtn}"  Command="{Binding ToggleSignCommand}"/>
            <Button Content="⌫"  Style="{StaticResource FnBtn}"  Command="{Binding BackspaceCommand}"/>
            <Button Content="÷"  Style="{StaticResource OpBtn}"  Command="{Binding OperatorCommand}" CommandParameter="/"/>

            <!-- Row 2: 7  8  9  × -->
            <Button Content="7"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="7"/>
            <Button Content="8"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="8"/>
            <Button Content="9"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="9"/>
            <Button Content="×"  Style="{StaticResource OpBtn}"    Command="{Binding OperatorCommand}" CommandParameter="*"/>

            <!-- Row 3: 4  5  6  − -->
            <Button Content="4"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="4"/>
            <Button Content="5"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="5"/>
            <Button Content="6"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="6"/>
            <Button Content="−"  Style="{StaticResource OpBtn}"    Command="{Binding OperatorCommand}" CommandParameter="-"/>

            <!-- Row 4: 1  2  3  + -->
            <Button Content="1"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="1"/>
            <Button Content="2"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="2"/>
            <Button Content="3"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="3"/>
            <Button Content="+"  Style="{StaticResource OpBtn}"    Command="{Binding OperatorCommand}" CommandParameter="+"/>

            <!-- Row 5: ±  0  .  = -->
            <Button Content="00" Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="00"/>
            <Button Content="0"  Style="{StaticResource DigitBtn}" Command="{Binding DigitCommand}" CommandParameter="0"/>
            <Button Content="."  Style="{StaticResource FnBtn}"    Command="{Binding DecimalCommand}"/>
            <Button Content="="  Style="{StaticResource EqBtn}"    Command="{Binding EqualsCommand}"/>
        </UniformGrid>
    </Grid>
</Window>
