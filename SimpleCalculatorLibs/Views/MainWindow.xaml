<Window x:Class="SimpleCalculatorLibs.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SimpleCalculatorLibs.ViewModels"
        Title="Calculator" Height="600" Width="320"
        MinHeight="500" MinWidth="250"
        Background="{DynamicResource WindowBackground}"
        Icon="/Resources/Icons/calculator.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Светлая тема по умолчанию -->
        <Color x:Key="WindowBackgroundColor">#F5F5FA</Color>
        <Color x:Key="DigitButtonBackgroundColor">#FFFFFF</Color>
        <Color x:Key="DigitButtonForegroundColor">#1E1E1E</Color>
        <Color x:Key="OperatorButtonBackgroundColor">#EBEBF5</Color>
        <Color x:Key="OperatorButtonForegroundColor">#6366F1</Color>
        <Color x:Key="EqualsButtonBackgroundColor">#6366F1</Color>
        <Color x:Key="EqualsButtonForegroundColor">#FFFFFF</Color>
        <Color x:Key="DisplayForegroundColor">#1E1E1E</Color>
        <Color x:Key="HistoryForegroundColor">#9696A0</Color>
        <Color x:Key="MenuBackgroundColor">#FFFFFF</Color>
        <Color x:Key="MenuBorderColor">#DCDCE6</Color>
        <Color x:Key="MenuItemForegroundColor">#1E1E1E</Color>
        <Color x:Key="ButtonHoverColor">#DCDCEB</Color>
        <Color x:Key="ButtonPressedColor">#C8C8DC</Color>
        <Color x:Key="MenuHoverColor">#F0F0FA</Color>
        <Color x:Key="MenuPressedColor">#E1E1F5</Color>
        <Color x:Key="MemoryButtonBackgroundColor">#E8F5E9</Color>
        <Color x:Key="MemoryButtonForegroundColor">#2E7D32</Color>
        <Color x:Key="StatusForegroundColor">#9696A0</Color>

        <SolidColorBrush x:Key="WindowBackground"          Color="{DynamicResource WindowBackgroundColor}"/>
        <SolidColorBrush x:Key="DigitButtonBackground"     Color="{DynamicResource DigitButtonBackgroundColor}"/>
        <SolidColorBrush x:Key="DigitButtonForeground"     Color="{DynamicResource DigitButtonForegroundColor}"/>
        <SolidColorBrush x:Key="OperatorButtonBackground"  Color="{DynamicResource OperatorButtonBackgroundColor}"/>
        <SolidColorBrush x:Key="OperatorButtonForeground"  Color="{DynamicResource OperatorButtonForegroundColor}"/>
        <SolidColorBrush x:Key="EqualsButtonBackground"    Color="{DynamicResource EqualsButtonBackgroundColor}"/>
        <SolidColorBrush x:Key="EqualsButtonForeground"    Color="{DynamicResource EqualsButtonForegroundColor}"/>
        <SolidColorBrush x:Key="DisplayForeground"         Color="{DynamicResource DisplayForegroundColor}"/>
        <SolidColorBrush x:Key="HistoryForeground"         Color="{DynamicResource HistoryForegroundColor}"/>
        <SolidColorBrush x:Key="MenuBackground"            Color="{DynamicResource MenuBackgroundColor}"/>
        <SolidColorBrush x:Key="MenuBorder"                Color="{DynamicResource MenuBorderColor}"/>
        <SolidColorBrush x:Key="MenuItemForeground"        Color="{DynamicResource MenuItemForegroundColor}"/>
        <SolidColorBrush x:Key="ButtonHover"               Color="{DynamicResource ButtonHoverColor}"/>
        <SolidColorBrush x:Key="ButtonPressed"             Color="{DynamicResource ButtonPressedColor}"/>
        <SolidColorBrush x:Key="MenuHover"                 Color="{DynamicResource MenuHoverColor}"/>
        <SolidColorBrush x:Key="MenuPressed"               Color="{DynamicResource MenuPressedColor}"/>
        <SolidColorBrush x:Key="MemoryButtonBackground"    Color="{DynamicResource MemoryButtonBackgroundColor}"/>
        <SolidColorBrush x:Key="MemoryButtonForeground"    Color="{DynamicResource MemoryButtonForegroundColor}"/>
        <SolidColorBrush x:Key="StatusForeground"          Color="{DynamicResource StatusForegroundColor}"/>

        <!-- Базовый стиль кнопки -->
        <Style x:Key="CalcButtonBase" TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonPressed}"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DigitButton" TargetType="Button"
               BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="{DynamicResource DigitButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource DigitButtonForeground}"/>
        </Style>

        <Style x:Key="OperatorButton" TargetType="Button"
               BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="{DynamicResource OperatorButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource OperatorButtonForeground}"/>
        </Style>

        <Style x:Key="EqualsButton" TargetType="Button"
               BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="{DynamicResource EqualsButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource EqualsButtonForeground}"/>
        </Style>

        <Style x:Key="MemoryButton" TargetType="Button"
               BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background"  Value="{DynamicResource MemoryButtonBackground}"/>
            <Setter Property="Foreground"  Value="{DynamicResource MemoryButtonForeground}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="ThemeMenuItem" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="HorizontalAlignment"      Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                  Value="8,6"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="Foreground"               Value="{DynamicResource MenuItemForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MenuHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MenuPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Звуки -->
        <MediaElement x:Name="RegularSound"
                      Source="/Resources/Sounds/regular_button_click.mp3"
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Volume="1" Visibility="Collapsed"/>
        <MediaElement x:Name="EqualsSound"
                      Source="/Resources/Sounds/equals_button_click.mp3"
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Volume="1" Visibility="Collapsed"/>

        <!-- Кнопка меню -->
        <ToggleButton x:Name="MenuToggleButton"
                      Width="32" Height="32" Margin="6,3,0,0"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      Background="Transparent" BorderThickness="0">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <Image Source="pack://application:,,,/Resources/Images/menu.png"
                               Width="auto" Height="auto"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource MenuHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <!-- Popup меню -->
        <Popup x:Name="MenuPopup"
               PlacementTarget="{Binding ElementName=MenuToggleButton}"
               Placement="Bottom" HorizontalOffset="0" VerticalOffset="5"
               StaysOpen="False"
               IsOpen="{Binding IsChecked, ElementName=MenuToggleButton, Mode=TwoWay}">
            <Border Background="{DynamicResource MenuBackground}"
                    BorderBrush="{DynamicResource MenuBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="4">
                <StackPanel MinWidth="180">
                    <Button x:Name="LightThemeButton"
                            Style="{StaticResource ThemeMenuItem}"
                            Click="LightThemeButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LightThemeCheck" Text="✓ "
                                       Visibility="Visible"
                                       Foreground="{DynamicResource OperatorButtonForeground}"/>
                            <TextBlock Text="Светлая тема"
                                       Foreground="{DynamicResource MenuItemForeground}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DarkThemeButton"
                            Style="{StaticResource ThemeMenuItem}"
                            Click="DarkThemeButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DarkThemeCheck" Text="✓ "
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource OperatorButtonForeground}"/>
                            <TextBlock Text="Тёмная тема"
                                       Foreground="{DynamicResource MenuItemForeground}"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="{DynamicResource MenuBorder}" Margin="4"/>
                    <Button Style="{StaticResource ThemeMenuItem}"
                            Click="OpenHelp_Click">
                        <TextBlock Text="О программе"
                                   Foreground="{DynamicResource MenuItemForeground}"/>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="10,4,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- История -->
            <TextBlock Grid.Row="0"
                       Text="{Binding HistoryText}"
                       Foreground="{DynamicResource HistoryForeground}"
                       FontSize="14" TextAlignment="Right"
                       Margin="0,0,6,0"/>

            <!-- Дисплей -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DisplayText}"
                       Foreground="{DynamicResource DisplayForeground}"
                       FontSize="46" FontWeight="SemiBold"
                       TextAlignment="Right"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,6,0"/>

            <!-- Статус памяти -->
            <TextBlock Grid.Row="2"
                       Text="{Binding MemoryStatus}"
                       Foreground="{DynamicResource StatusForeground}"
                       FontSize="11" TextAlignment="Left"
                       Margin="2,0,0,4"/>

            <!-- Кнопки памяти -->
            <UniformGrid Grid.Row="3" Rows="1" Columns="4" Margin="0,0,0,4">
                <Button Content="MS" Style="{StaticResource MemoryButton}"
                        Command="{Binding MemoryStoreCommand}"/>
                <Button Content="M+" Style="{StaticResource MemoryButton}"
                        Command="{Binding MemoryAddCommand}"/>
                <Button Content="MR" Style="{StaticResource MemoryButton}"
                        Command="{Binding MemoryRecallCommand}"/>
                <Button Content="MC" Style="{StaticResource MemoryButton}"
                        Command="{Binding MemoryClearCommand}"/>
            </UniformGrid>

            <!-- Кнопки калькулятора -->
            <Grid Grid.Row="4" Margin="0,2,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ряд 0 -->
                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="C" Style="{StaticResource OperatorButton}"
                        Command="{Binding ClearCommand}"/>
                <Button Grid.Row="0" Grid.Column="2" Content="⌫"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding BackspaceCommand}"/>
                <Button Grid.Row="0" Grid.Column="3" Content="="
                        Style="{StaticResource EqualsButton}"
                        Command="{Binding EqualsCommand}"/>

                <!-- Ряд 1 -->
                <Button Grid.Row="1" Grid.Column="0" Content="7"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="7"/>
                <Button Grid.Row="1" Grid.Column="1" Content="8"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="8"/>
                <Button Grid.Row="1" Grid.Column="2" Content="9"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="9"/>
                <Button Grid.Row="1" Grid.Column="3" Content="×"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding OperatorCommand}" CommandParameter="*"/>

                <!-- Ряд 2 -->
                <Button Grid.Row="2" Grid.Column="0" Content="4"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="4"/>
                <Button Grid.Row="2" Grid.Column="1" Content="5"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="5"/>
                <Button Grid.Row="2" Grid.Column="2" Content="6"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="6"/>
                <Button Grid.Row="2" Grid.Column="3" Content="−"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding OperatorCommand}" CommandParameter="-"/>

                <!-- Ряд 3 -->
                <Button Grid.Row="3" Grid.Column="0" Content="1"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="1"/>
                <Button Grid.Row="3" Grid.Column="1" Content="2"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="2"/>
                <Button Grid.Row="3" Grid.Column="2" Content="3"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="3"/>
                <Button Grid.Row="3" Grid.Column="3" Content="+"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding OperatorCommand}" CommandParameter="+"/>

                <!-- Ряд 4 -->
                <Button Grid.Row="4" Grid.Column="0" Content="0"
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DigitCommand}" CommandParameter="0"/>
                <Button Grid.Row="4" Grid.Column="1" Content="."
                        Style="{StaticResource DigitButton}"
                        Command="{Binding DecimalCommand}"/>
                <Button Grid.Row="4" Grid.Column="2" Content="π"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding PiCommand}"/>
                <Button Grid.Row="4" Grid.Column="3" Content="÷"
                        Style="{StaticResource OperatorButton}"
                        Command="{Binding OperatorCommand}" CommandParameter="/"/>
            </Grid>
        </Grid>
    </Grid>
</Window>