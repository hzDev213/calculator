<Window x:Class="SimpleCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Height="500" Width="320"
        MinHeight="400" MinWidth="250"
        Background="#1E1E1E"
        PreviewKeyDown="Window_KeyDown" 
        Focusable="True">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="Foreground" Value="#4CC2FF"/>
        </Style>

        <Style x:Key="EqualButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#4CC2FF"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/> <RowDefinition Height="3*"/> <RowDefinition Height="2*"/> <RowDefinition Height="2*"/> <RowDefinition Height="2*"/> <RowDefinition Height="2*"/> <RowDefinition Height="2*"/> <RowDefinition Height="2*"/> </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="HistoryText" Grid.Row="0" Grid.ColumnSpan="4" Foreground="#888888" FontSize="16" TextAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,0"/>
        <TextBlock x:Name="DisplayText" Grid.Row="1" Grid.ColumnSpan="4" Foreground="White" FontSize="48" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Text="0"/>

        <Button Content="sin" Grid.Row="2" Grid.Column="0" Style="{StaticResource OperatorButton}" Click="Button_MathFunction_Click"/>
        <Button Content="cos" Grid.Row="2" Grid.Column="1" Style="{StaticResource OperatorButton}" Click="Button_MathFunction_Click"/>
        <Button Content="sqrt" Grid.Row="2" Grid.Column="2" Style="{StaticResource OperatorButton}" Click="Button_MathFunction_Click"/>
        <Button Content=")" Grid.Row="2" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Button_Number_Click"/>

        <Button Content="C" Grid.Row="3" Grid.Column="0" Style="{StaticResource OperatorButton}" Click="Button_Clear_Click"/>
        <Button Content="⌫" Grid.Row="3" Grid.Column="1" Style="{StaticResource OperatorButton}" Click="Button_Backspace_Click"/>
        <Button Content="π" Grid.Row="3" Grid.Column="2" Style="{StaticResource OperatorButton}" Click="Button_Number_Click"/>
        <Button Content="/" Grid.Row="3" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Button_Operator_Click"/>

        <Button Content="7" Grid.Row="4" Grid.Column="0" Click="Button_Number_Click"/>
        <Button Content="8" Grid.Row="4" Grid.Column="1" Click="Button_Number_Click"/>
        <Button Content="9" Grid.Row="4" Grid.Column="2" Click="Button_Number_Click"/>
        <Button Content="*" Grid.Row="4" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Button_Operator_Click"/>

        <Button Content="4" Grid.Row="5" Grid.Column="0" Click="Button_Number_Click"/>
        <Button Content="5" Grid.Row="5" Grid.Column="1" Click="Button_Number_Click"/>
        <Button Content="6" Grid.Row="5" Grid.Column="2" Click="Button_Number_Click"/>
        <Button Content="-" Grid.Row="5" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Button_Operator_Click"/>

        <Button Content="1" Grid.Row="6" Grid.Column="0" Click="Button_Number_Click"/>
        <Button Content="2" Grid.Row="6" Grid.Column="1" Click="Button_Number_Click"/>
        <Button Content="3" Grid.Row="6" Grid.Column="2" Click="Button_Number_Click"/>
        <Button Content="+" Grid.Row="6" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Button_Operator_Click"/>

        <Button Content="0" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Click="Button_Number_Click"/>
        <Button Content="," Grid.Row="7" Grid.Column="2" Click="Button_Decimal_Click"/>
        <Button Content="=" Grid.Row="7" Grid.Column="3" Style="{StaticResource EqualButton}" Click="Button_Equals_Click"/>
    </Grid>
</Window>